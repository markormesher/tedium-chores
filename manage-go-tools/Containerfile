FROM docker.io/golang:1.26.1@sha256:cdebbd553e5ed852386e9772e429031467fa44ca3a06735e6beb005d615e623d
WORKDIR /app

RUN apt update \
  && apt install -y --no-install-recommends jq \
  && rm -rf /var/lib/apt/lists/*

COPY ./manage-go-tools.sh /usr/local/bin/.
RUN chmod +x /usr/local/bin/manage-go-tools.sh

CMD ["/usr/local/bin/manage-go-tools.sh"]

LABEL image.name=markormesher/tedium-chore-manage-go-tools
LABEL image.registry=ghcr.io
LABEL org.opencontainers.image.description=""
LABEL org.opencontainers.image.documentation=""
LABEL org.opencontainers.image.title="tedium-chores"
LABEL org.opencontainers.image.url="https://github.com/markormesher/tedium-chores"
LABEL org.opencontainers.image.vendor=""
LABEL org.opencontainers.image.version=""
