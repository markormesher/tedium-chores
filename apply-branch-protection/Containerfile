FROM docker.io/debian:13.4-slim@sha256:109e2c65005bf160609e4ba6acf7783752f8502ad218e298253428690b9eaa4b
WORKDIR /app

RUN apt update \
  && apt install -y --no-install-recommends curl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY ./apply-branch-protection.sh /usr/local/bin/.
RUN chmod +x /usr/local/bin/apply-branch-protection.sh

CMD ["/usr/local/bin/apply-branch-protection.sh"]

LABEL image.name=markormesher/tedium-chore-apply-branch-protection
LABEL image.registry=ghcr.io
LABEL org.opencontainers.image.description=""
LABEL org.opencontainers.image.documentation=""
LABEL org.opencontainers.image.title="tedium-chores"
LABEL org.opencontainers.image.url="https://github.com/markormesher/tedium-chores"
LABEL org.opencontainers.image.vendor=""
LABEL org.opencontainers.image.version=""
